{
  "name": "defrag",
  "version": "1.1.0",
  "description": "defragment dependencies in your monorepo",
  "keywords": [
    "defrag",
    "dependencies",
    "deps",
    "fix",
    "defragmentation"
  ],
  "repository": {
    "type": "https",
    "url": "https://github.com/NullVoxPopuli/defrag"
  },
  "license": "MIT",
  "author": "NullVoxPopuli",
  "type": "module",
  "exports": {
    "import": "./src/index.js"
  },
  "bin": {
    "defrag": "./bin.js",
    "defrag-dependencies": "./bin.js"
  },
  "files": [
    "index.js",
    "src/**",
    "bin.js"
  ],
  "scripts": {
    "build": "tsc --build",
    "lint": "oxlint && oxfmt --check",
    "lint:fix": "oxlint --fix && oxfmt",
    "lint:types": "tsc --noEmit",
    "test": "vitest --coverage --no-watch",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@manypkg/get-packages": "^2.2.0",
    "cosmiconfig": "^9.0.0",
    "debug": "^4.3.4",
    "ember-apply": "^2.11.1",
    "latest-version": "^7.0.0",
    "minimatch": "^9.0.3",
    "semver": "^7.5.4",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.2",
    "@tsconfig/strictest": "^2.0.2",
    "@types/debug": "^4.1.12",
    "@types/semver": "^7.5.5",
    "@vitest/coverage-c8": "^0.33.0",
    "@vitest/coverage-v8": "^0.34.6",
    "c8": "^8.0.1",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "release-plan": "^0.18.0",
    "typescript": "5.3.3",
    "vite": "^5.0.0",
    "vitest": "^0.34.6"
  },
  "engines": {
    "node": ">=22.11.0"
  },
  "preset": "index.js"
}
